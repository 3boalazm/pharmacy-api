{
  "name": "pharmacy-api",
  "version": "1.0.0",
  "private": true,
  "description": "Pharmacy SaaS — NestJS modular monolith (Architecture Decision Doc v1.0)",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "start:dev": "ts-node src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy && psql $DATABASE_URL -f prisma/sql/001_invariants.sql",
    "seed": "ts-node prisma/seed.ts",
    "import:items": "ts-node prisma/import-items.ts",
    "start": "node dist/src/main.js",
    "db:push": "prisma db push",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --ci"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.10",
    "@nestjs/core": "^10.3.10",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/schedule": "^4.1.0",
    "@prisma/client": "^5.17.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "prisma": "^5.17.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@types/jest": "^29.5.14",
    "@nestjs/testing": "^10.0.0"
  },
  "engines": {
    "node": ">=20 <23"
  }
}
